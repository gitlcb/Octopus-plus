        "circuitBreaker": {
            "title": "Circuit Breaker",
            "threshold": {
                "label": "Failure Threshold (consecutive failures)",
                "placeholder": "Enter threshold"
            },
            "cooldown": {
                "label": "Base Cooldown (seconds)",
                "placeholder": "Enter cooldown in seconds"
            },
            "maxCooldown": {
                "label": "Max Cooldown (seconds)",
                "placeholder": "Enter max cooldown in seconds"
            },
            "hint": "When a channel fails consecutively up to the threshold, circuit breaker trips. Cooldown grows exponentially up to the max cooldown"
        },
        "outlierRetirement": {
            "title": "Passive Outlier Retirement",
            "hint": "Temporarily disables site projected channels that keep failing on real requests (disabled, never deleted), then probes them periodically and re-enables them once they recover. Before disabling, sibling channels of the same site are cross-checked and a probe request confirms the failure to avoid false positives; at least one enabled channel is always kept per account. Applies only to site projected channels. Off by default.",
            "enabled": {
                "label": "Enable Passive Outlier Retirement"
            },
            "interval": {
                "label": "Evaluation Interval (minutes)",
                "description": "How often the background task runs one round of evaluation and recovery probing.",
                "placeholder": "Enter interval in minutes"
            },
            "failRate": {
                "label": "Failure Rate Threshold (%)",
                "description": "A channel is considered abnormal only when the failure ratio within the window reaches this value.",
                "placeholder": "Enter failure rate percent"
            },
            "minSamples": {
                "label": "Minimum Samples",
                "description": "Evaluation is skipped while the window holds fewer requests than this, avoiding misjudgment on sparse traffic.",
                "placeholder": "Enter minimum samples"
            },
            "consecFails": {
                "label": "Consecutive Failure Threshold",
                "description": "After the failure rate is met, the most recent consecutive failures must also reach this count (or the window has no success at all).",
                "placeholder": "Enter consecutive failures"
            },
            "windowMinutes": {
                "label": "Rolling Window Duration (minutes)",
                "description": "Only requests within this recent period are counted; older records expire automatically.",
                "placeholder": "Enter window minutes"
            },
            "windowCapacity": {
                "label": "Window Sample Capacity (≤20)",
                "description": "Maximum number of request records kept per window; the oldest are dropped first.",
                "placeholder": "Enter sample capacity"
            },
            "recoverStreak": {
                "label": "Probe Successes to Recover",
                "description": "A retired channel is re-enabled after this many consecutive successful probes.",
                "placeholder": "Enter success count"
            },
            "reapMinutes": {
                "label": "Idle Window Reap (minutes)",
                "description": "Frees a channel's in-memory stats window after it has received no new requests for this long.",
                "placeholder": "Enter reap minutes"
            },
            "cfRecoverMinutes": {
                "label": "Cloudflare Recovery Cooldown (minutes)",
                "description": "Channels retired due to Cloudflare protection wait this long before recovery probing starts, to reduce pointless probes.",
                "placeholder": "Enter cooldown minutes"
            }
        },
